#!/usr/bin/env python3
# This file is placed in the Public Domain.


"gcid genocide bot"


import os
import readline


from gcid.obj.dbs import Class, Config, Db, find, fntime, last, save
from gcid.obj.fnc import edit, format, register
from gcid.run.cbs import Callbacks
from gcid.run.cmd import Commands, dispatch
from gcid.run.shl import Shell
from gcid.exc.dmn import cprint
from gcid.exc.scn import init, introspect, scan
from gcid.exc.wrp import wrap
from gcid.exc.utl import wait


from gcid.obj import Object, get, keys, update


Config.name = "gcid"
Config.workdir = os.path.expanduser("~/.genocide")


class Console(Shell):

    def raw(self, txt):
        cprint(txt)


def cmd(event):
    event.reply(",".join(sorted(Commands.cmd)))


Commands.add(cmd)


def main():
    Callbacks.add("command", dispatch)
    scan("gcid")
    c = Console()
    c.start()
    wait()


wrap(main)
